<% content_for :title, "Trabajadores" %>
<% content_for :page_title, "Trabajadores" %>

<section class="trabajadores-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Trabajadores</h3>
        <p class="panel__description">
          Consulta, filtra y administra los trabajadores registrados en el sistema.
        </p>
      </div>

      <% if puede_realizar_accion?(:trabajadores, :crear) %>
        <%= link_to "Nuevo trabajador", new_trabajador_path, class: "button button--primary" %>
      <% end %>
    </div>

    <%= form_with url: trabajadores_path, method: :get, local: true, class: "filtros-panel" do %>
      <div class="filtros-grid filtros-grid--trabajadores">
        <div class="form-field">
          <label for="q">Buscar</label>
          <%= text_field_tag :q,
                             @q,
                             class: "form-input",
                             placeholder: "Nombre, RFC, CURP o clave de cobro" %>
        </div>

        <div class="form-field">
          <label for="concepto07_nivel_id">Categoría</label>
          <%= select_tag :concepto07_nivel_id,
                         options_for_select(
                           [["Todas", ""]] + @categorias.map { |categoria| ["#{categoria.nombre} (#{categoria.clave})", categoria.id] },
                           @concepto07_nivel_id
                         ),
                         class: "form-input" %>
        </div>

        <div class="form-field">
          <label for="estado_trabajador">Estado</label>
          <%= select_tag :estado_trabajador,
                         options_for_select(
                           [["Todos", ""]] + Trabajador.estado_trabajadores.keys.map { |valor| [valor.humanize, valor] },
                           @estado_trabajador
                         ),
                         class: "form-input" %>
        </div>

        <div class="form-field">
          <label for="sexo">Sexo</label>
          <%= select_tag :sexo,
                         options_for_select(
                           [["Todos", ""]] + Trabajador.sexos.keys.map { |valor| [valor.humanize, valor] },
                           @sexo
                         ),
                         class: "form-input" %>
        </div>

        <div class="form-field">
          <label for="tipo_trabajador">Tipo de trabajador</label>
          <%= select_tag :tipo_trabajador,
                         options_for_select(
                           [["Todos", ""]] + Trabajador.tipo_trabajadores.keys.map { |valor| [valor.humanize, valor] },
                           @tipo_trabajador
                         ),
                         class: "form-input" %>
        </div>
      </div>

      <div class="filtros-actions">
        <%= submit_tag "Filtrar", class: "button button--primary" %>
        <%= link_to "Limpiar", trabajadores_path, class: "button button--ghost" %>
      </div>
    <% end %>

    <% if @trabajadores.any? %>
      <div class="listado-meta">
        <span>
          Mostrando <strong><%= @trabajadores.size %></strong> de
          <strong><%= @total_registros %></strong> trabajadores
        </span>

        <span>
          Página <strong><%= @pagina_actual %></strong> de
          <strong><%= @total_paginas %></strong>
        </span>
      </div>

      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Trabajador</th>
              <th>RFC</th>
              <th>Tipo</th>
              <th>Sexo</th>
              <th>Categoría</th>
              <th>Concepto 07</th>
              <th>Estado</th>
              <th>Condonado habitual</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% @trabajadores.each do |trabajador| %>
              <tr>
                <td>
                  <strong><%= trabajador.nombre_completo %></strong>
                  <br>
                  <small><%= trabajador.clave_cobro %></small>
                </td>

                <td><%= trabajador.rfc %></td>

                <td><%= trabajador.tipo_trabajador&.humanize || "-" %></td>

                <td><%= trabajador.sexo&.humanize || "-" %></td>

                <td><%= trabajador.concepto07_nivel&.nombre || "-" %></td>

                <td>
                  <%= trabajador.concepto07_monto.present? ? number_to_currency(trabajador.concepto07_monto) : "-" %>
                </td>

                <td>
                  <span class="estado-badge estado-badge--<%= trabajador.estado_trabajador %>">
                    <%= trabajador.estado_trabajador&.humanize || "-" %>
                  </span>
                </td>

                <td>
                  <% if trabajador.condonado_habitual? %>
                    <span class="estado-badge estado-badge--condonado">Sí</span>
                  <% else %>
                    <span class="estado-badge estado-badge--pendiente">No</span>
                  <% end %>
                </td>

                <td class="tabla-base__acciones">
                  <div class="acciones-grupo">
                    <%= link_to "Ver", trabajador_path(trabajador), class: "button button--ghost" %>

                    <% if puede_realizar_accion?(:trabajadores, :editar) %>
                      <%= link_to "Editar", edit_trabajador_path(trabajador), class: "button button--primary" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_paginas.to_i > 1 %>
        <div class="pagination">
          <% if @pagina_actual > 1 %>
            <%= link_to "← Anterior",
                        trabajadores_path(request.query_parameters.merge(page: @pagina_actual - 1)),
                        class: "button button--ghost" %>
          <% end %>

          <% (1..@total_paginas).each do |pagina| %>
            <%= link_to pagina,
                        trabajadores_path(request.query_parameters.merge(page: pagina)),
                        class: "pagination__link #{'is-active' if pagina == @pagina_actual}" %>
          <% end %>

          <% if @pagina_actual < @total_paginas %>
            <%= link_to "Siguiente →",
                        trabajadores_path(request.query_parameters.merge(page: @pagina_actual + 1)),
                        class: "button button--ghost" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        No se encontraron trabajadores con los filtros seleccionados.
      </div>
    <% end %>
  </div>
</section>