<%= form_with model: trabajador,
              class: "formulario-base",
              data: { controller: "categoria-selector" },
              novalidate: true do |f| %>
  <% if trabajador.errors.any? %>
    <div class="form-errors">
      <strong>No se pudo guardar el trabajador:</strong>
      <ul>
        <% trabajador.errors.full_messages.each do |mensaje| %>
          <li><%= mensaje %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="form-field">
      <%= f.label :nombres, "Nombres" %>
      <%= f.text_field :nombres,
                       class: "form-input #{'form-input--error' if trabajador.errors[:nombres].any?}",
                       minlength: 3,
                       maxlength: 100 %>
      <% if trabajador.errors[:nombres].any? %>
        <small class="field-error"><%= trabajador.errors[:nombres].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :apellido_paterno, "Apellido paterno" %>
      <%= f.text_field :apellido_paterno,
                       class: "form-input #{'form-input--error' if trabajador.errors[:apellido_paterno].any?}",
                       minlength: 3,
                       maxlength: 100 %>
      <% if trabajador.errors[:apellido_paterno].any? %>
        <small class="field-error"><%= trabajador.errors[:apellido_paterno].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :apellido_materno, "Apellido materno" %>
      <%= f.text_field :apellido_materno,
                       class: "form-input #{'form-input--error' if trabajador.errors[:apellido_materno].any?}",
                       minlength: 3,
                       maxlength: 100 %>
      <% if trabajador.errors[:apellido_materno].any? %>
        <small class="field-error"><%= trabajador.errors[:apellido_materno].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :sexo, "Sexo" %>
      <%= f.select :sexo,
                   Trabajador.sexos.keys.map { |valor| [valor.humanize, valor] },
                   { prompt: "Selecciona una opción" },
                   class: "form-input #{'form-input--error' if trabajador.errors[:sexo].any?}" %>
      <% if trabajador.errors[:sexo].any? %>
        <small class="field-error"><%= trabajador.errors[:sexo].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :tipo_trabajador, "Tipo de trabajador" %>
      <%= f.select :tipo_trabajador,
                   Trabajador.tipo_trabajadores.keys.map { |valor| [valor.humanize, valor] },
                   { prompt: "Selecciona una opción" },
                   class: "form-input #{'form-input--error' if trabajador.errors[:tipo_trabajador].any?}" %>
      <% if trabajador.errors[:tipo_trabajador].any? %>
        <small class="field-error"><%= trabajador.errors[:tipo_trabajador].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :fecha_ingreso, "Fecha de ingreso" %>
      <%= f.date_field :fecha_ingreso,
                       class: "form-input #{'form-input--error' if trabajador.errors[:fecha_ingreso].any?}",
                       max: Date.current %>
      <% if trabajador.errors[:fecha_ingreso].any? %>
        <small class="field-error"><%= trabajador.errors[:fecha_ingreso].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :rfc, "RFC" %>
      <%= f.text_field :rfc,
                       class: "form-input #{'form-input--error' if trabajador.errors[:rfc].any?}",
                       maxlength: 13 %>
      <% if trabajador.errors[:rfc].any? %>
        <small class="field-error"><%= trabajador.errors[:rfc].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :curp, "CURP" %>
      <%= f.text_field :curp,
                       class: "form-input #{'form-input--error' if trabajador.errors[:curp].any?}",
                       maxlength: 18 %>
      <% if trabajador.errors[:curp].any? %>
        <small class="field-error"><%= trabajador.errors[:curp].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :clave_cobro, "Clave de cobro" %>
      <%= f.text_field :clave_cobro,
                       class: "form-input #{'form-input--error' if trabajador.errors[:clave_cobro].any?}",
                       minlength: 3,
                       maxlength: 30 %>
      <% if trabajador.errors[:clave_cobro].any? %>
        <small class="field-error"><%= trabajador.errors[:clave_cobro].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <label>CT</label>
      <input type="text" class="form-input" value="<%= Trabajador::CT_FIJO %>" disabled>
      <small class="helper-text">Dato fijo para todos los trabajadores.</small>
    </div>

    <div class="form-field">
      <%= f.label :telefono, "Teléfono" %>
      <%= f.text_field :telefono,
                       class: "form-input #{'form-input--error' if trabajador.errors[:telefono].any?}",
                       inputmode: "numeric",
                       maxlength: 10 %>
      <% if trabajador.errors[:telefono].any? %>
        <small class="field-error"><%= trabajador.errors[:telefono].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :correo, "Correo" %>
      <%= f.email_field :correo,
                        class: "form-input #{'form-input--error' if trabajador.errors[:correo].any?}",
                        maxlength: 150 %>
      <% if trabajador.errors[:correo].any? %>
        <small class="field-error"><%= trabajador.errors[:correo].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :codigo_postal, "Código postal" %>
      <%= f.text_field :codigo_postal,
                       class: "form-input #{'form-input--error' if trabajador.errors[:codigo_postal].any?}",
                       inputmode: "numeric",
                       maxlength: 5 %>
      <% if trabajador.errors[:codigo_postal].any? %>
        <small class="field-error"><%= trabajador.errors[:codigo_postal].first %></small>
      <% end %>
    </div>

    <% if trabajador.persisted? %>
      <div class="form-field">
        <%= f.label :estado_trabajador, "Estado del trabajador" %>
        <%= f.select :estado_trabajador,
                     Trabajador.estado_trabajadores.keys.map { |valor| [valor.humanize, valor] },
                     {},
                     class: "form-input #{'form-input--error' if trabajador.errors[:estado_trabajador].any?}" %>
        <% if trabajador.errors[:estado_trabajador].any? %>
          <small class="field-error"><%= trabajador.errors[:estado_trabajador].first %></small>
        <% end %>
      </div>
    <% else %>
      <div class="form-field">
        <label>Estado del trabajador</label>
        <input type="text" class="form-input" value="Activo" disabled>
        <small class="helper-text">Al registrar un trabajador se crea con estado activo.</small>
      </div>
    <% end %>

    <div class="form-field">
      <%= f.label :concepto07_nivel_id, "Categoría" %>
      <%= f.select :concepto07_nivel_id,
                   options_for_select(
                     categorias.map { |categoria| ["#{categoria.nombre} (#{categoria.clave})", categoria.id, { data: { monto: categoria.monto_concepto07 } }] },
                     trabajador.concepto07_nivel_id
                   ),
                   { prompt: "Selecciona una categoría" },
                   class: "form-input #{'form-input--error' if trabajador.errors[:concepto07_nivel].any? || trabajador.errors[:concepto07_nivel_id].any?}",
                   data: {
                     action: "change->categoria-selector#actualizarMonto",
                     categoria_selector_target: "select"
                   } %>
      <% if trabajador.errors[:concepto07_nivel].any? %>
        <small class="field-error"><%= trabajador.errors[:concepto07_nivel].first %></small>
      <% elsif trabajador.errors[:concepto07_nivel_id].any? %>
        <small class="field-error"><%= trabajador.errors[:concepto07_nivel_id].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <label>Concepto 07</label>
      <input type="text"
             class="form-input"
             value="<%= trabajador.concepto07_monto.present? ? number_to_currency(trabajador.concepto07_monto) : '' %>"
             placeholder="Se llenará automáticamente"
             readonly
             data-categoria-selector-target="monto">
      <small class="helper-text">Se toma automáticamente de la categoría seleccionada.</small>
    </div>

    <div class="form-field">
      <label>Periodicidad de pago</label>
      <input type="text" class="form-input" value="Quincenal" disabled>
      <small class="helper-text">Dato fijo para todos los trabajadores.</small>
    </div>

    <div class="form-field">
      <div class="checkbox-field">
        <%= f.check_box :condonado_habitual %>
        <%= f.label :condonado_habitual, "Condonado habitual" %>
      </div>

      <small class="helper-text">
        Si está marcado, este trabajador se agregará automáticamente como condonado al crear nuevas cooperaciones.
      </small>

      <% if trabajador.errors[:condonado_habitual].any? %>
        <small class="field-error"><%= trabajador.errors[:condonado_habitual].first %></small>
      <% end %>
    </div>

    <div class="form-field form-field--full">
      <%= f.label :direccion, "Dirección" %>
      <%= f.text_area :direccion,
                      class: "form-input form-textarea #{'form-input--error' if trabajador.errors[:direccion].any?}",
                      rows: 4,
                      minlength: 10,
                      maxlength: 255 %>
      <% if trabajador.errors[:direccion].any? %>
        <small class="field-error"><%= trabajador.errors[:direccion].first %></small>
      <% end %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar",
                trabajador.persisted? ? trabajador_path(trabajador) : trabajadores_path,
                class: "button button--ghost" %>

    <%= f.submit trabajador.persisted? ? "Actualizar trabajador" : "Guardar trabajador",
                 class: "button button--primary" %>
  </div>
<% end %>