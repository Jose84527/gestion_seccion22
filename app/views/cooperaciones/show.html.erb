<% content_for :title, "Detalle de cooperación" %>
<% content_for :page_title, "Detalle de cooperación" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3><%= @cooperacion.nombre %></h3>
        <p class="panel__description">
          Detalle general de la corrida de cooperación.
        </p>
      </div>

      <div class="acciones-grupo">
        <%= link_to "Volver", cooperaciones_path, class: "button button--ghost" %>

        <% if puede_realizar_accion?(:cooperaciones, :editar) && @cooperacion.activa? %>
          <%= link_to "Editar", edit_cooperacion_path(@cooperacion), class: "button button--primary" %>
        <% end %>
      </div>
    </div>

    <div class="detalle-grid">
      <div class="detalle-item">
        <span class="detalle-item__label">Estado</span>
        <strong>
          <span class="estado-badge estado-badge--<%= @cooperacion.estado %>">
            <%= @cooperacion.estado.humanize %>
          </span>
        </strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Cuenta financiera</span>
        <strong><%= @cooperacion.cuenta_financiera&.nombre || "-" %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Fecha inicio</span>
        <strong><%= @cooperacion.fecha_inicio_vigencia&.strftime("%d/%m/%Y") || "-" %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Fecha fin</span>
        <strong><%= @cooperacion.fecha_fin_vigencia&.strftime("%d/%m/%Y") || "-" %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Conceptos</span>
        <strong><%= @cooperacion.cantidad_conceptos %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Condonados</span>
        <strong><%= @cooperacion.cantidad_condonados %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Total esperado</span>
        <strong><%= number_to_currency(@total_esperado) %></strong>
      </div>

      <% if @cooperacion.completada? %>
        <div class="detalle-item">
          <span class="detalle-item__label">Confirmada el</span>
          <strong><%= @cooperacion.confirmada_at&.strftime("%d/%m/%Y %H:%M") || "-" %></strong>
        </div>

        <div class="detalle-item">
          <span class="detalle-item__label">Confirmada por</span>
          <strong><%= @cooperacion.confirmada_por&.nombre_usuario || "-" %></strong>
        </div>

        <div class="detalle-item">
          <span class="detalle-item__label">Datos congelados el</span>
          <strong><%= @cooperacion.snapshot_generado_at&.strftime("%d/%m/%Y %H:%M") || "-" %></strong>
        </div>
      <% end %>
    </div>
  </div>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Conceptos incluidos</h3>
        <p class="panel__description">
          Conceptos aplicados en esta corrida.
        </p>
      </div>
    </div>

    <% if @cooperacion.cooperacion_conceptos.any? %>
      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Concepto</th>
              <th>Descripción</th>
              <th>Tipo</th>
              <th>Monto fijo</th>
              <th>Porcentaje</th>
            </tr>
          </thead>

          <tbody>
            <% @cooperacion.cooperacion_conceptos.each do |concepto| %>
              <tr>
                <td><strong><%= concepto.nombre %></strong></td>
                <td><%= concepto.descripcion.presence || "-" %></td>
                <td><%= concepto.tipo_cooperacion&.humanize || "-" %></td>
                <td><%= concepto.monto_fijo.present? ? number_to_currency(concepto.monto_fijo) : "-" %></td>
                <td><%= concepto.porcentaje.present? ? "#{concepto.porcentaje}%" : "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        Esta cooperación no tiene conceptos registrados.
      </div>
    <% end %>
  </div>

  <div class="panel" id="desglose-trabajadores">
    <div class="panel__header">
      <div>
        <h3>Desglose por trabajador</h3>
        <p class="panel__description">
          <% if @cooperacion.completada? %>
            Datos congelados al momento de confirmar la cooperación.
          <% else %>
            Vista previa de importes individuales antes de generar recibos o lista general.
          <% end %>
        </p>
      </div>
    </div>

    <% desglose_paginado = @desglose_trabajadores_paginados || @desglose_trabajadores %>

    <% if @desglose_trabajadores.any? %>
      <% if @total_desglose_registros.present? %>
        <div class="listado-meta">
          <span>
            Mostrando <strong><%= desglose_paginado.size %></strong> de
            <strong><%= @total_desglose_registros %></strong> trabajadores
          </span>

          <span>
            Página <strong><%= @desglose_pagina_actual %></strong> de
            <strong><%= @desglose_total_paginas %></strong>
          </span>
        </div>
      <% end %>

      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Trabajador</th>
              <th>Tipo</th>
              <th>Categoría</th>
              <th>Concepto 07</th>
              <th>Estado</th>
              <th>Desglose</th>
              <th>Total</th>
            </tr>
          </thead>

          <tbody>
            <% desglose_paginado.each do |fila_original| %>
              <% fila = fila_original.respond_to?(:with_indifferent_access) ? fila_original.with_indifferent_access : {} %>
              <% trabajador = fila[:trabajador] %>

              <% nombre_trabajador = fila[:nombre_trabajador].presence || fila[:nombre].presence || trabajador&.nombre_completo || "Trabajador sin nombre" %>
              <% rfc_trabajador = fila[:rfc].presence || trabajador&.rfc || "-" %>
              <% clave_cobro = fila[:clave_cobro].presence || trabajador&.clave_cobro || "-" %>
              <% tipo_trabajador = fila[:tipo_trabajador].presence || trabajador&.tipo_trabajador %>
              <% categoria_nombre = fila[:categoria_nombre].presence || trabajador&.concepto07_nivel&.nombre || "-" %>
              <% concepto07_monto = fila[:concepto07].presence || fila[:concepto07_monto].presence || trabajador&.concepto07_monto || 0 %>
              <% conceptos_fila = fila[:conceptos].presence || fila[:detalle_conceptos].presence || [] %>

              <tr>
                <td>
                  <strong><%= nombre_trabajador %></strong>
                  <br>
                  <small><%= rfc_trabajador %> · <%= clave_cobro %></small>
                </td>

                <td><%= tipo_trabajador.present? ? tipo_trabajador.to_s.humanize : "-" %></td>

                <td><%= categoria_nombre %></td>

                <td><%= number_to_currency(concepto07_monto.to_d) %></td>

                <td>
                  <% if fila[:condonado] %>
                    <span class="estado-badge estado-badge--condonado">Condonado</span>
                  <% else %>
                    <span class="estado-badge estado-badge--pendiente">Pendiente</span>
                  <% end %>
                </td>

                <td>
                  <% if fila[:condonado] %>
                    <strong>CONDONADO</strong>
                  <% else %>
                    <% if conceptos_fila.any? %>
                      <div class="desglose-conceptos">
                        <% conceptos_fila.each do |concepto_original| %>
                          <% concepto = concepto_original.respond_to?(:with_indifferent_access) ? concepto_original.with_indifferent_access : {} %>

                          <div class="desglose-conceptos__item">
                            <span><%= concepto[:nombre].presence || "Concepto" %></span>
                            <strong><%= number_to_currency(concepto[:importe].to_d) %></strong>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <span>-</span>
                    <% end %>
                  <% end %>
                </td>

                <td>
                  <strong><%= number_to_currency(fila[:total].to_d) %></strong>
                </td>
              </tr>
            <% end %>
          </tbody>

          <tfoot>
            <tr>
              <td colspan="6" class="tabla-total-label">Total esperado</td>
              <td><strong><%= number_to_currency(@total_esperado) %></strong></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <% if @desglose_total_paginas.to_i > 1 %>
        <div class="pagination">
          <% if @desglose_pagina_actual > 1 %>
            <%= link_to "← Anterior",
                        cooperacion_path(
                          @cooperacion,
                          request.query_parameters.merge(
                            desglose_page: @desglose_pagina_actual - 1,
                            anchor: "desglose-trabajadores"
                          )
                        ),
                        class: "button button--ghost" %>
          <% end %>

          <% (1..@desglose_total_paginas).each do |pagina| %>
            <%= link_to pagina,
                        cooperacion_path(
                          @cooperacion,
                          request.query_parameters.merge(
                            desglose_page: pagina,
                            anchor: "desglose-trabajadores"
                          )
                        ),
                        class: "pagination__link #{'is-active' if pagina == @desglose_pagina_actual}" %>
          <% end %>

          <% if @desglose_pagina_actual < @desglose_total_paginas %>
            <%= link_to "Siguiente →",
                        cooperacion_path(
                          @cooperacion,
                          request.query_parameters.merge(
                            desglose_page: @desglose_pagina_actual + 1,
                            anchor: "desglose-trabajadores"
                          )
                        ),
                        class: "button button--ghost" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        No hay trabajadores activos para calcular esta cooperación.
      </div>
    <% end %>
  </div>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Trabajadores condonados</h3>
        <p class="panel__description">
          Trabajadores exentos dentro de esta corrida.
        </p>
      </div>
    </div>

    <% filas_condonadas = @desglose_trabajadores.select do |fila_original|
      fila = fila_original.respond_to?(:with_indifferent_access) ? fila_original.with_indifferent_access : {}
      fila[:condonado]
    end %>

    <% if filas_condonadas.any? %>
      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Trabajador</th>
              <th>RFC</th>
              <th>Tipo</th>
            </tr>
          </thead>

          <tbody>
            <% filas_condonadas.each do |fila_original| %>
              <% fila = fila_original.respond_to?(:with_indifferent_access) ? fila_original.with_indifferent_access : {} %>
              <% trabajador = fila[:trabajador] %>

              <% nombre_trabajador = fila[:nombre_trabajador].presence || fila[:nombre].presence || trabajador&.nombre_completo || "Trabajador sin nombre" %>
              <% rfc_trabajador = fila[:rfc].presence || trabajador&.rfc || "-" %>
              <% tipo_trabajador = fila[:tipo_trabajador].presence || trabajador&.tipo_trabajador %>

              <tr>
                <td><%= nombre_trabajador %></td>
                <td><%= rfc_trabajador %></td>
                <td><%= tipo_trabajador.present? ? tipo_trabajador.to_s.humanize : "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        No hay trabajadores condonados en esta cooperación.
      </div>
    <% end %>
  </div>

  <% if @cooperacion.completada? %>
    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Confirmación de cooperación</h3>
          <p class="panel__description">
            Evidencia registrada al completar la corrida.
          </p>
        </div>
      </div>

      <div class="detalle-grid">
        <div class="detalle-item">
          <span class="detalle-item__label">Fecha de confirmación</span>
          <strong><%= @cooperacion.confirmada_at&.strftime("%d/%m/%Y %H:%M") || "-" %></strong>
        </div>

        <div class="detalle-item">
          <span class="detalle-item__label">Confirmada por</span>
          <strong><%= @cooperacion.confirmada_por&.nombre_usuario || "-" %></strong>
        </div>

        <div class="detalle-item">
          <span class="detalle-item__label">Total congelado</span>
          <strong><%= number_to_currency(@cooperacion.total_confirmado_snapshot || @total_esperado) %></strong>
        </div>
      </div>

      <div class="detalle-bloque">
        <span class="detalle-item__label">Archivo PDF escaneado</span>
        <p><%= @cooperacion.lista_confirmacion_pdf_path.presence || "-" %></p>
      </div>

      <% if @cooperacion.lista_confirmacion_pdf_path.present? %>
        <div class="finanzas-actions">
          <%= link_to "Ver PDF escaneado",
                      ver_lista_confirmacion_cooperacion_path(@cooperacion),
                      class: "button button--primary",
                      target: "_blank",
                      rel: "noopener" %>

          <% if puede_realizar_accion?(:cooperaciones, :editar) %>
            <%= link_to "Corregir PDF de evidencia",
                        corregir_evidencia_cooperacion_path(@cooperacion),
                        class: "button button--ghost" %>
          <% end %>
        </div>
      <% end %>

      <div class="detalle-bloque">
        <span class="detalle-item__label">Observaciones</span>

        <% if @cooperacion.observaciones_confirmacion.present? %>
          <div class="observaciones-confirmacion">
            <%= simple_format(@cooperacion.observaciones_confirmacion) %>
          </div>
        <% else %>
          <p>-</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Documentos</h3>
        <p class="panel__description">
          Exportación en PDF de recibos y lista general.
        </p>
      </div>
    </div>

    <div class="finanzas-actions">
      <%= link_to "Generar PDF de recibos",
                  pdf_recibos_cooperacion_path(@cooperacion),
                  class: "button button--ghost",
                  target: "_blank",
                  rel: "noopener" %>

      <%= link_to "Generar PDF de lista general",
                  pdf_lista_general_cooperacion_path(@cooperacion),
                  class: "button button--ghost",
                  target: "_blank",
                  rel: "noopener" %>

      <% if puede_realizar_accion?(:cooperaciones, :editar) && @cooperacion.activa? %>
        <%= link_to "Confirmar cooperación",
                    confirmacion_cooperacion_path(@cooperacion),
                    class: "button button--primary" %>
      <% elsif @cooperacion.completada? %>
        <span class="button button--ghost is-disabled">Cooperación completada</span>
      <% elsif @cooperacion.cancelada? %>
        <span class="button button--ghost is-disabled">Cooperación cancelada</span>
      <% end %>
    </div>
  </div>
</section>