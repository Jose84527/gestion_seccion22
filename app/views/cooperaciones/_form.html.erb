<%= form_with model: cooperacion,
              class: "formulario-base",
              data: {
                controller: "cooperacion-form condonados-selector",
                action: "submit->cooperacion-form#enableAllDisabledFields",
                "condonados-selector-url-value": buscar_trabajadores_cooperaciones_path
              },
              novalidate: true do |f| %>
  <% if cooperacion.errors.any? %>
    <div class="form-errors">
      <strong>No se pudo guardar la cooperación:</strong>
      <ul>
        <% cooperacion.errors.full_messages.each do |mensaje| %>
          <li><%= mensaje %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-section">
    <div class="form-section__header">
      <h4>Datos generales</h4>
      <p>Información principal de la corrida de cooperación.</p>
    </div>

    <div class="form-grid form-grid--dos-columnas">
      <div class="form-field">
        <%= f.label :nombre, "Nombre de la cooperación" %>
        <%= f.text_field :nombre,
                         class: "form-input #{'form-input--error' if cooperacion.errors[:nombre].any?}",
                         minlength: 3,
                         maxlength: 100 %>
        <% if cooperacion.errors[:nombre].any? %>
          <small class="field-error"><%= cooperacion.errors[:nombre].first %></small>
        <% end %>
      </div>

      <div class="form-field">
        <label>Estado</label>
        <input type="text" class="form-input" value="<%= cooperacion.estado.presence&.humanize || 'Activa' %>" disabled>
        <small class="helper-text">Al crear una cooperación queda activa por default.</small>
      </div>

      <div class="form-field">
        <%= f.label :fecha_inicio_vigencia, "Fecha inicio" %>
        <%= f.date_field :fecha_inicio_vigencia,
                         class: "form-input #{'form-input--error' if cooperacion.errors[:fecha_inicio_vigencia].any?}" %>
        <% if cooperacion.errors[:fecha_inicio_vigencia].any? %>
          <small class="field-error"><%= cooperacion.errors[:fecha_inicio_vigencia].first %></small>
        <% end %>
      </div>

      <div class="form-field">
        <%= f.label :fecha_fin_vigencia, "Fecha fin" %>
        <%= f.date_field :fecha_fin_vigencia,
                         class: "form-input #{'form-input--error' if cooperacion.errors[:fecha_fin_vigencia].any?}" %>
        <% if cooperacion.errors[:fecha_fin_vigencia].any? %>
          <small class="field-error"><%= cooperacion.errors[:fecha_fin_vigencia].first %></small>
        <% end %>
      </div>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section__header form-section__header--actions">
      <div>
        <h4>Conceptos de cooperación</h4>
        <p>Agrega uno o varios conceptos para esta corrida.</p>
      </div>

      <button type="button"
              class="button button--ghost"
              data-action="click->cooperacion-form#addConcepto">
        Agregar concepto
      </button>
    </div>

    <% if cooperacion.errors[:cooperacion_conceptos].any? %>
      <small class="field-error"><%= cooperacion.errors[:cooperacion_conceptos].first %></small>
    <% end %>

    <div data-cooperacion-form-target="conceptos">
      <%= f.fields_for :cooperacion_conceptos do |concepto_form| %>
        <%= render "concepto_fields", f: concepto_form %>
      <% end %>
    </div>

    <template data-cooperacion-form-target="template">
      <%= f.fields_for :cooperacion_conceptos, CooperacionConcepto.new, child_index: "NEW_RECORD" do |concepto_form| %>
        <%= render "concepto_fields", f: concepto_form %>
      <% end %>
    </template>
  </div>

  <div class="form-section">
    <div class="form-section__header">
      <h4>Condonados</h4>
      <p>
  Agrega trabajadores exentos para esta corrida de cooperación.
  Los trabajadores marcados como condonados habituales se cargan automáticamente al crear una nueva cooperación.
</p>
    </div>

    <div class="condonados-selector">
      <div class="form-field">
        <label for="buscar_condonado_query">Buscar trabajador</label>
        <input type="text"
               id="buscar_condonado_query"
               class="form-input"
               placeholder="Escribe nombre, RFC o clave de cobro"
               autocomplete="off"
               data-action="input->condonados-selector#search"
               data-condonados-selector-target="query">

        <small class="helper-text">Escribe al menos 2 caracteres para buscar trabajadores activos.</small>
      </div>

      <div class="trabajador-selector__results"
           data-condonados-selector-target="results"
           hidden></div>

      <div class="condonados-list"
           data-condonados-selector-target="list">
        <%= f.fields_for :cooperacion_condonados do |condonado_form| %>
          <% trabajador = condonado_form.object.trabajador %>

          <div class="condonado-item"
               data-condonados-selector-target="item"
               data-trabajador-id="<%= condonado_form.object.trabajador_id %>">
            <%= condonado_form.hidden_field :id if condonado_form.object.persisted? %>
            <%= condonado_form.hidden_field :trabajador_id %>
            <%= condonado_form.hidden_field :_destroy,
                                            value: "0",
                                            data: { destroy_field: "true" } %>

            <span>
              <strong><%= trabajador&.nombre_completo || "Trabajador" %></strong>
              <% if trabajador.present? %>
                <small><%= trabajador.rfc %> · <%= trabajador.clave_cobro %></small>
              <% end %>
            </span>

            <button type="button"
                    class="button button--ghost"
                    data-action="click->condonados-selector#removeExisting">
              Quitar
            </button>
          </div>
        <% end %>
      </div>

      <template data-condonados-selector-target="template">
        <div class="condonado-item"
             data-condonados-selector-target="item"
             data-trabajador-id="TRABAJADOR_ID">
          <input type="hidden" name="cooperacion[cooperacion_condonados_attributes][NEW_RECORD][trabajador_id]" value="TRABAJADOR_ID">
          <span>
            <strong>TRABAJADOR_NOMBRE</strong>
            <small>TRABAJADOR_META</small>
          </span>
          <button type="button"
                  class="button button--ghost"
                  data-action="click->condonados-selector#removeNew">
            Quitar
          </button>
        </div>
      </template>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar",
                cooperacion.persisted? ? cooperacion_path(cooperacion) : cooperaciones_path,
                class: "button button--ghost" %>

    <%= f.submit cooperacion.persisted? ? "Actualizar cooperación" : "Guardar cooperación",
                 class: "button button--primary" %>
  </div>
<% end %>