<%= form_with model: cooperacion, class: "formulario-base" do |f| %>
  <% if cooperacion.errors.any? %>
    <div class="form-errors">
      <strong>No se pudo guardar la cooperación:</strong>
      <ul>
        <% cooperacion.errors.full_messages.each do |mensaje| %>
          <li><%= mensaje %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid form-grid--dos-columnas">
    <div class="form-field">
      <%= f.label :nombre, "Nombre" %>
      <%= f.text_field :nombre,
                       class: "form-input #{'form-input--error' if cooperacion.errors[:nombre].any?}",
                       minlength: 3,
                       maxlength: 100 %>
      <% if cooperacion.errors[:nombre].any? %>
        <small class="field-error"><%= cooperacion.errors[:nombre].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :tipo_cooperacion, "Tipo de cooperación" %>
      <%= f.select :tipo_cooperacion,
                   [
                     ["Porcentaje", "porcentaje"],
                     ["Monto fijo", "monto_fijo"],
                     ["Mixta", "mixta"]
                   ],
                   { prompt: "Selecciona un tipo" },
                   class: "form-input #{'form-input--error' if cooperacion.errors[:tipo_cooperacion].any?}" %>
      <% if cooperacion.errors[:tipo_cooperacion].any? %>
        <small class="field-error"><%= cooperacion.errors[:tipo_cooperacion].first %></small>
      <% end %>
    </div>

    <div class="form-field form-field--full">
      <%= f.label :descripcion, "Descripción" %>
      <%= f.text_area :descripcion,
                      class: "form-input form-textarea #{'form-input--error' if cooperacion.errors[:descripcion].any?}",
                      rows: 4,
                      maxlength: 255 %>
      <% if cooperacion.errors[:descripcion].any? %>
        <small class="field-error"><%= cooperacion.errors[:descripcion].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :monto_fijo_base, "Monto fijo base" %>
      <%= f.number_field :monto_fijo_base,
                         class: "form-input #{'form-input--error' if cooperacion.errors[:monto_fijo_base].any?}",
                         step: "0.01",
                         min: 0 %>
      <% if cooperacion.errors[:monto_fijo_base].any? %>
        <small class="field-error"><%= cooperacion.errors[:monto_fijo_base].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :periodicidad_generacion, "Periodicidad" %>
      <%= f.select :periodicidad_generacion,
                   [
                     ["Única", "unica"],
                     ["Semanal", "semanal"],
                     ["Quincenal", "quincenal"],
                     ["Mensual", "mensual"]
                   ],
                   { prompt: "Selecciona una periodicidad" },
                   class: "form-input #{'form-input--error' if cooperacion.errors[:periodicidad_generacion].any?}" %>
      <% if cooperacion.errors[:periodicidad_generacion].any? %>
        <small class="field-error"><%= cooperacion.errors[:periodicidad_generacion].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :fecha_inicio_vigencia, "Fecha inicio de vigencia" %>
      <%= f.date_field :fecha_inicio_vigencia,
                       class: "form-input #{'form-input--error' if cooperacion.errors[:fecha_inicio_vigencia].any?}" %>
      <% if cooperacion.errors[:fecha_inicio_vigencia].any? %>
        <small class="field-error"><%= cooperacion.errors[:fecha_inicio_vigencia].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :fecha_fin_vigencia, "Fecha fin de vigencia" %>
      <%= f.date_field :fecha_fin_vigencia,
                       class: "form-input #{'form-input--error' if cooperacion.errors[:fecha_fin_vigencia].any?}" %>
      <% if cooperacion.errors[:fecha_fin_vigencia].any? %>
        <small class="field-error"><%= cooperacion.errors[:fecha_fin_vigencia].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :es_recurrente, "¿Es recurrente?" %>
      <%= f.select :es_recurrente,
                   [["Sí", true], ["No", false]],
                   {},
                   class: "form-input #{'form-input--error' if cooperacion.errors[:es_recurrente].any?}" %>
      <% if cooperacion.errors[:es_recurrente].any? %>
        <small class="field-error"><%= cooperacion.errors[:es_recurrente].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :activa, "Estado" %>
      <%= f.select :activa,
                   [["Activa", true], ["Inactiva", false]],
                   {},
                   class: "form-input #{'form-input--error' if cooperacion.errors[:activa].any?}" %>
      <% if cooperacion.errors[:activa].any? %>
        <small class="field-error"><%= cooperacion.errors[:activa].first %></small>
      <% end %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", cooperaciones_path, class: "button button--ghost" %>
    <%= f.submit cooperacion.persisted? ? "Actualizar cooperación" : "Guardar cooperación",
                 class: "button button--primary" %>
  </div>
<% end %>