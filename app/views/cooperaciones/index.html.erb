<% content_for :title, "Control de cooperaciones" %>
<% content_for :page_title, "Control de cooperaciones" %>

<% cuenta_params = @cuenta_financiera_actual.present? ? { cuenta_financiera_id: @cuenta_financiera_actual.id } : {} %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Control de cooperaciones</h3>
        <p class="panel__description">
          Corridas de cooperación generadas para recibos, listas y control financiero.
        </p>
      </div>

      <% if puede_realizar_accion?(:cooperaciones, :crear) %>
        <%= link_to "Nueva cooperación",
                    new_cooperacion_path(cuenta_params),
                    class: "button button--primary" %>
      <% end %>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Cuenta financiera</span>

      <% if admin_actual? %>
        <p>
          <strong><%= @cuenta_financiera_actual&.nombre || "Todas las cuentas financieras" %></strong>
        </p>
      <% else %>
        <p>
          <strong><%= @cuenta_financiera_actual&.nombre || "Sin cuenta financiera asignada" %></strong>
        </p>
      <% end %>
    </div>

    <%= form_with url: cooperaciones_path, method: :get, local: true, class: "filtros-panel" do %>
      <div class="filtros-grid filtros-grid--cooperaciones">
        <% if admin_actual? %>
          <div class="form-field">
            <label for="cuenta_financiera_id">Cuenta financiera</label>
            <%= select_tag :cuenta_financiera_id,
                           options_from_collection_for_select(
                             @cuentas_financieras || [],
                             :id,
                             :nombre,
                             @cuenta_financiera_actual&.id
                           ),
                           include_blank: "Todas las cuentas financieras",
                           class: "form-input" %>
          </div>
        <% end %>

        <div class="form-field">
          <label for="q">Buscar por nombre</label>
          <%= text_field_tag :q,
                             @q,
                             class: "form-input",
                             placeholder: "Ejemplo: Guelaguetza, mayo, bono..." %>
        </div>

        <div class="form-field">
          <label for="estado">Estado</label>
          <%= select_tag :estado,
                         options_for_select(
                           [
                             ["Todos", ""],
                             ["Activa", "activa"],
                             ["Completada", "completada"],
                             ["Cancelada", "cancelada"]
                           ],
                           @estado
                         ),
                         class: "form-input" %>
        </div>
      </div>

      <div class="filtros-actions">
        <%= submit_tag "Filtrar", class: "button button--primary" %>
        <%= link_to "Limpiar", cooperaciones_path, class: "button button--ghost" %>
      </div>
    <% end %>

    <% if @cooperaciones.any? %>
      <div class="listado-meta">
        <span>
          Mostrando <strong><%= @cooperaciones.size %></strong> de
          <strong><%= @total_registros %></strong> cooperaciones
        </span>

        <span>
          Página <strong><%= @pagina_actual %></strong> de
          <strong><%= @total_paginas %></strong>
        </span>
      </div>

      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Nombre</th>

              <% if admin_actual? && @cuenta_financiera_actual.blank? %>
                <th>Cuenta financiera</th>
              <% end %>

              <th>Vigencia</th>
              <th>Conceptos</th>
              <th>Condonados</th>
              <th>Total esperado</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% @cooperaciones.each do |cooperacion| %>
              <tr>
                <td><%= cooperacion.nombre %></td>

                <% if admin_actual? && @cuenta_financiera_actual.blank? %>
                  <td><%= cooperacion.cuenta_financiera&.nombre || "-" %></td>
                <% end %>

                <td>
                  <%= cooperacion.fecha_inicio_vigencia&.strftime("%d/%m/%Y") || "-" %>
                  -
                  <%= cooperacion.fecha_fin_vigencia&.strftime("%d/%m/%Y") || "-" %>
                </td>

                <td><%= cooperacion.cantidad_conceptos %></td>
                <td><%= cooperacion.cantidad_condonados %></td>
                <td><%= number_to_currency(cooperacion.total_esperado) %></td>

                <td>
                  <span class="estado-badge estado-badge--<%= cooperacion.estado %>">
                    <%= cooperacion.estado.humanize %>
                  </span>
                </td>

                <td class="tabla-base__acciones">
                  <div class="acciones-grupo">
                    <%= link_to "Ver", cooperacion_path(cooperacion), class: "button button--ghost" %>

                    <% if puede_realizar_accion?(:cooperaciones, :editar) && cooperacion.activa? %>
                      <%= link_to "Editar",
                                  edit_cooperacion_path(cooperacion),
                                  class: "button button--ghost" %>

                      <%= link_to "Confirmar",
                                  confirmacion_cooperacion_path(cooperacion),
                                  class: "button button--primary" %>

                      <%= button_to "Cancelar",
                                    cambiar_estado_cooperacion_path(cooperacion),
                                    method: :patch,
                                    class: "button button--ghost" %>
                    <% elsif puede_realizar_accion?(:cooperaciones, :editar) && cooperacion.cancelada? %>
                      <%= button_to "Reactivar",
                                    cambiar_estado_cooperacion_path(cooperacion),
                                    method: :patch,
                                    class: "button button--ghost" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_paginas.to_i > 1 %>
        <div class="pagination">
          <% if @pagina_actual > 1 %>
            <%= link_to "← Anterior",
                        cooperaciones_path(request.query_parameters.merge(page: @pagina_actual - 1)),
                        class: "button button--ghost" %>
          <% end %>

          <% (1..@total_paginas).each do |pagina| %>
            <%= link_to pagina,
                        cooperaciones_path(request.query_parameters.merge(page: pagina)),
                        class: "pagination__link #{'is-active' if pagina == @pagina_actual}" %>
          <% end %>

          <% if @pagina_actual < @total_paginas %>
            <%= link_to "Siguiente →",
                        cooperaciones_path(request.query_parameters.merge(page: @pagina_actual + 1)),
                        class: "button button--ghost" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        No se encontraron cooperaciones con los filtros seleccionados.
      </div>
    <% end %>
  </div>
</section>