<% content_for :title, "Control de cooperaciones" %>
<% content_for :page_title, "Control de cooperaciones" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Control de cooperaciones</h3>
        <p class="panel__description">
          Corridas de cooperación generadas para recibos, listas y control financiero.
        </p>
      </div>

      <% if puede_realizar_accion?(:cooperaciones, :crear) %>
        <%= link_to "Nueva cooperación", new_cooperacion_path, class: "button button--primary" %>
      <% end %>
    </div>

    <% if @cooperaciones.any? %>
      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Vigencia</th>
              <th>Conceptos</th>
              <th>Condonados</th>
              <th>Total esperado</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% @cooperaciones.each do |cooperacion| %>
              <tr>
                <td><%= cooperacion.nombre %></td>
                <td>
                  <%= cooperacion.fecha_inicio_vigencia&.strftime("%d/%m/%Y") || "-" %>
                  -
                  <%= cooperacion.fecha_fin_vigencia&.strftime("%d/%m/%Y") || "-" %>
                </td>
                <td><%= cooperacion.cantidad_conceptos %></td>
                <td><%= cooperacion.cantidad_condonados %></td>
                <td><%= number_to_currency(cooperacion.total_esperado) %></td>
                <td>
                  <span class="estado-badge estado-badge--<%= cooperacion.estado %>">
                    <%= cooperacion.estado.humanize %>
                  </span>
                </td>
                <td class="tabla-base__acciones">
                  <%= link_to "Ver", cooperacion_path(cooperacion), class: "button button--ghost" %>

                  <% if puede_realizar_accion?(:cooperaciones, :editar) && !cooperacion.completada? %>
                    <%= link_to "Editar", edit_cooperacion_path(cooperacion), class: "button button--ghost" %>

                    <%= button_to(
                          cooperacion.activa? ? "Cancelar" : "Reactivar",
                          cambiar_estado_cooperacion_path(cooperacion),
                          method: :patch,
                          class: "button button--ghost"
                        ) %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        Aún no hay corridas de cooperación registradas.
      </div>
    <% end %>
  </div>
</section>