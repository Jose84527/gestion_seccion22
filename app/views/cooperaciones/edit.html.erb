<% content_for :title, "Editar cooperación" %>
<% content_for :page_title, "Editar cooperación" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Editar corrida de cooperación</h3>
        <p class="panel__description">
          Modifica los datos generales, conceptos o trabajadores condonados.
        </p>
      </div>

      <%= link_to "Volver", cooperacion_path(@cooperacion), class: "button button--ghost" %>
    </div>

    <%= render "form", cooperacion: @cooperacion %>
  </div>
</section>