<% content_for :title, "Reportes financieros" %>
<% content_for :page_title, "Reportes financieros" %>

<% modo_global = admin_actual? && @cuenta_financiera_actual.blank? %>

<section class="finanzas-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Reportes financieros</h3>
        <p class="panel__description">
          Consulta ingresos confirmados, egresos confirmados y saldo financiero por periodo.
          Si el admin selecciona todas las cuentas, los datos se muestran separados por secretaría.
        </p>
      </div>

      <%= link_to "Volver al dashboard",
                  finanzas_path(cuenta_financiera_id: @cuenta_financiera_actual&.id),
                  class: "button button--ghost" %>
    </div>

    <%= form_with url: finanzas_reportes_path, method: :get, local: true, class: "filtros-panel" do %>
      <div class="filtros-grid filtros-grid--trabajadores">
        <% if admin_actual? %>
          <div class="form-field">
            <label for="cuenta_financiera_id">Cuenta financiera</label>
            <%= select_tag :cuenta_financiera_id,
                           options_from_collection_for_select(
                             @cuentas_financieras || [],
                             :id,
                             :nombre,
                             @cuenta_financiera_actual&.id
                           ),
                           include_blank: "Todas las cuentas financieras",
                           class: "form-input" %>
          </div>
        <% else %>
          <div class="form-field">
            <label>Cuenta financiera</label>
            <input type="text"
                   class="form-input"
                   value="<%= @cuenta_financiera_actual&.nombre || 'Sin cuenta financiera asignada' %>"
                   disabled>
          </div>
        <% end %>

        <div class="form-field">
          <label for="tipo">Tipo de reporte</label>
          <%= select_tag :tipo,
                         options_for_select(
                           [
                             ["Reporte general", "general"],
                             ["Solo ingresos", "ingresos"],
                             ["Solo egresos", "egresos"]
                           ],
                           @tipo
                         ),
                         class: "form-input" %>
        </div>

        <div class="form-field">
          <label for="fecha_inicio">Fecha inicio</label>
          <%= date_field_tag :fecha_inicio, @fecha_inicio, class: "form-input" %>
        </div>

        <div class="form-field">
          <label for="fecha_fin">Fecha fin</label>
          <%= date_field_tag :fecha_fin, @fecha_fin, class: "form-input" %>
        </div>
      </div>

      <div class="filtros-actions">
        <%= submit_tag "Generar reporte", class: "button button--primary" %>

        <%= link_to "Exportar Excel",
                    finanzas_reportes_excel_path(
                      tipo: @tipo,
                      fecha_inicio: @fecha_inicio,
                      fecha_fin: @fecha_fin,
                      cuenta_financiera_id: @cuenta_financiera_actual&.id
                    ),
                    class: "button button--ghost" %>

        <%= link_to "Limpiar", finanzas_reportes_path, class: "button button--ghost" %>
      </div>
    <% end %>
  </div>

  <% if modo_global %>
    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Resumen por cuentas financieras</h3>
          <p class="panel__description">
            Vista global del administrador. Los datos se separan por cuenta y no se mezclan en un solo total.
          </p>
        </div>
      </div>

      <% if @reportes_por_cuenta.present? && @reportes_por_cuenta.any? %>
        <div class="tabla-wrapper">
          <table class="tabla-base">
            <thead>
              <tr>
                <th>Cuenta financiera</th>
                <th>Ingresos confirmados</th>
                <th>Egresos confirmados</th>
                <th>Saldo</th>
                <th>Ingresos</th>
                <th>Egresos</th>
              </tr>
            </thead>

            <tbody>
              <% @reportes_por_cuenta.each do |reporte| %>
                <tr>
                  <td><strong><%= reporte[:cuenta].nombre %></strong></td>
                  <td><%= number_to_currency(reporte[:total_ingresos]) %></td>
                  <td><%= number_to_currency(reporte[:total_egresos]) %></td>
                  <td><strong><%= number_to_currency(reporte[:saldo_final]) %></strong></td>
                  <td><%= reporte[:ingresos].size %></td>
                  <td><%= reporte[:egresos].size %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">
          No hay cuentas financieras activas para consultar.
        </div>
      <% end %>
    </div>

    <% @reportes_por_cuenta.each do |reporte| %>
      <div class="panel">
        <div class="panel__header">
          <div>
            <h3><%= reporte[:cuenta].nombre %></h3>
            <p class="panel__description">
              Reporte exclusivo de esta cuenta financiera.
            </p>
          </div>

          <div class="acciones-grupo">
            <%= link_to "Ver dashboard",
                        finanzas_path(cuenta_financiera_id: reporte[:cuenta].id),
                        class: "button button--ghost" %>

            <%= link_to "Ver reportes de esta cuenta",
                        finanzas_reportes_path(
                          tipo: @tipo,
                          fecha_inicio: @fecha_inicio,
                          fecha_fin: @fecha_fin,
                          cuenta_financiera_id: reporte[:cuenta].id
                        ),
                        class: "button button--primary" %>
          </div>
        </div>

        <div class="finanzas-grid">
          <div class="finanzas-card">
            <span class="finanzas-card__label">Ingresos confirmados</span>
            <strong class="finanzas-card__value">
              <%= number_to_currency(reporte[:total_ingresos]) %>
            </strong>
          </div>

          <div class="finanzas-card">
            <span class="finanzas-card__label">Egresos confirmados</span>
            <strong class="finanzas-card__value">
              <%= number_to_currency(reporte[:total_egresos]) %>
            </strong>
          </div>

          <div class="finanzas-card">
            <span class="finanzas-card__label">Saldo final</span>
            <strong class="finanzas-card__value">
              <%= number_to_currency(reporte[:saldo_final]) %>
            </strong>
          </div>
        </div>

        <% if @tipo.in?(%w[general ingresos]) %>
          <div class="panel__subsection">
            <h4>Detalle de ingresos</h4>
          </div>

          <% if reporte[:ingresos].any? %>
            <div class="tabla-wrapper">
              <table class="tabla-base">
                <thead>
                  <tr>
                    <th>Cooperación</th>
                    <th>Fecha de confirmación</th>
                    <th>Conceptos</th>
                    <th>Condonados</th>
                    <th>Total</th>
                    <th></th>
                  </tr>
                </thead>

                <tbody>
                  <% reporte[:ingresos].each do |cooperacion| %>
                    <tr>
                      <td><strong><%= cooperacion.nombre %></strong></td>
                      <td><%= cooperacion.confirmada_at&.strftime("%d/%m/%Y %H:%M") || "-" %></td>
                      <td><%= cooperacion.cantidad_conceptos %></td>
                      <td><%= cooperacion.cantidad_condonados %></td>
                      <td><strong><%= number_to_currency(cooperacion.total_esperado) %></strong></td>
                      <td class="tabla-base__acciones">
                        <%= link_to "Ver", cooperacion_path(cooperacion), class: "button button--ghost" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>

                <tfoot>
                  <tr>
                    <td colspan="4" class="tabla-total-label">Total de ingresos</td>
                    <td colspan="2">
                      <strong><%= number_to_currency(reporte[:total_ingresos]) %></strong>
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% else %>
            <div class="empty-state">
              No hay ingresos confirmados para esta cuenta en el periodo seleccionado.
            </div>
          <% end %>
        <% end %>

        <% if @tipo.in?(%w[general egresos]) %>
          <div class="panel__subsection">
            <h4>Detalle de egresos</h4>
          </div>

          <% if reporte[:egresos].any? %>
            <div class="tabla-wrapper">
              <table class="tabla-base">
                <thead>
                  <tr>
                    <th>Folio</th>
                    <th>Fecha del egreso</th>
                    <th>Concepto</th>
                    <th>Confirmado el</th>
                    <th>Monto</th>
                    <th></th>
                  </tr>
                </thead>

                <tbody>
                  <% reporte[:egresos].each do |egreso| %>
                    <tr>
                      <td><strong><%= egreso.folio_np %></strong></td>
                      <td><%= egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></td>
                      <td><%= egreso.concepto %></td>
                      <td><%= egreso.confirmado_at&.strftime("%d/%m/%Y %H:%M") || "-" %></td>
                      <td><strong><%= number_to_currency(egreso.monto) %></strong></td>
                      <td class="tabla-base__acciones">
                        <%= link_to "Ver", egreso_path(egreso), class: "button button--ghost" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>

                <tfoot>
                  <tr>
                    <td colspan="4" class="tabla-total-label">Total de egresos</td>
                    <td colspan="2">
                      <strong><%= number_to_currency(reporte[:total_egresos]) %></strong>
                    </td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% else %>
            <div class="empty-state">
              No hay egresos confirmados para esta cuenta en el periodo seleccionado.
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Resumen del periodo</h3>
          <p class="panel__description">
            Cuenta financiera:
            <strong><%= @cuenta_financiera_actual&.nombre || "Sin cuenta financiera" %></strong>
            <br>

            <% if @fecha_inicio.present? || @fecha_fin.present? %>
              Periodo consultado:
              <strong><%= @fecha_inicio&.strftime("%d/%m/%Y") || "inicio" %></strong>
              -
              <strong><%= @fecha_fin&.strftime("%d/%m/%Y") || "actualidad" %></strong>
            <% else %>
              Consulta general sin rango de fechas.
            <% end %>
          </p>
        </div>
      </div>

      <div class="finanzas-grid">
        <div class="finanzas-card">
          <span class="finanzas-card__label">Ingresos confirmados</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@total_ingresos || 0) %>
          </strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Egresos confirmados</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@total_egresos || 0) %>
          </strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Saldo final</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@saldo_final || 0) %>
          </strong>
        </div>
      </div>
    </div>

    <% if @tipo.in?(%w[general ingresos]) %>
      <div class="panel">
        <div class="panel__header">
          <div>
            <h3>Detalle de ingresos</h3>
            <p class="panel__description">
              Cooperaciones completadas dentro del periodo seleccionado.
            </p>
          </div>
        </div>

        <% if @ingresos.any? %>
          <div class="tabla-wrapper">
            <table class="tabla-base">
              <thead>
                <tr>
                  <th>Cooperación</th>
                  <th>Fecha de confirmación</th>
                  <th>Conceptos</th>
                  <th>Condonados</th>
                  <th>Total</th>
                  <th></th>
                </tr>
              </thead>

              <tbody>
                <% @ingresos.each do |cooperacion| %>
                  <tr>
                    <td><strong><%= cooperacion.nombre %></strong></td>
                    <td><%= cooperacion.confirmada_at&.strftime("%d/%m/%Y %H:%M") || "-" %></td>
                    <td><%= cooperacion.cantidad_conceptos %></td>
                    <td><%= cooperacion.cantidad_condonados %></td>
                    <td><strong><%= number_to_currency(cooperacion.total_esperado) %></strong></td>
                    <td class="tabla-base__acciones">
                      <%= link_to "Ver", cooperacion_path(cooperacion), class: "button button--ghost" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>

              <tfoot>
                <tr>
                  <td colspan="4" class="tabla-total-label">Total de ingresos</td>
                  <td colspan="2">
                    <strong><%= number_to_currency(@total_ingresos || 0) %></strong>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        <% else %>
          <div class="empty-state">
            No hay ingresos confirmados para este periodo.
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @tipo.in?(%w[general egresos]) %>
      <div class="panel">
        <div class="panel__header">
          <div>
            <h3>Detalle de egresos</h3>
            <p class="panel__description">
              Egresos confirmados dentro del periodo seleccionado.
            </p>
          </div>
        </div>

        <% if @egresos.any? %>
          <div class="tabla-wrapper">
            <table class="tabla-base">
              <thead>
                <tr>
                  <th>Folio</th>
                  <th>Fecha del egreso</th>
                  <th>Concepto</th>
                  <th>Confirmado el</th>
                  <th>Monto</th>
                  <th></th>
                </tr>
              </thead>

              <tbody>
                <% @egresos.each do |egreso| %>
                  <tr>
                    <td><strong><%= egreso.folio_np %></strong></td>
                    <td><%= egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></td>
                    <td><%= egreso.concepto %></td>
                    <td><%= egreso.confirmado_at&.strftime("%d/%m/%Y %H:%M") || "-" %></td>
                    <td><strong><%= number_to_currency(egreso.monto) %></strong></td>
                    <td class="tabla-base__acciones">
                      <%= link_to "Ver", egreso_path(egreso), class: "button button--ghost" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>

              <tfoot>
                <tr>
                  <td colspan="4" class="tabla-total-label">Total de egresos</td>
                  <td colspan="2">
                    <strong><%= number_to_currency(@total_egresos || 0) %></strong>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        <% else %>
          <div class="empty-state">
            No hay egresos confirmados para este periodo.
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</section>