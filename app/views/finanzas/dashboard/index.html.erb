<% content_for :title, "Finanzas" %>
<% content_for :page_title, "Dashboard financiero" %>

<% cuenta_params = @cuenta_financiera_actual.present? ? { cuenta_financiera_id: @cuenta_financiera_actual.id } : {} %>
<% modo_global = admin_actual? && @cuenta_financiera_actual.blank? %>

<section class="finanzas-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Dashboard financiero</h3>
        <p class="panel__description">
          Resumen financiero separado por cuenta. Cuando se visualizan todas las cuentas, los datos no se mezclan entre secretarías.
        </p>
      </div>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Cuenta financiera</span>

      <% if admin_actual? %>
        <%= form_with url: finanzas_path, method: :get, local: true, class: "filtros-panel filtros-panel--inline" do %>
          <div class="filtros-inline">
            <div class="form-field filtros-inline__field">
              <%= select_tag :cuenta_financiera_id,
                             options_from_collection_for_select(
                               @cuentas_financieras || [],
                               :id,
                               :nombre,
                               @cuenta_financiera_actual&.id
                             ),
                             include_blank: "Todas las cuentas financieras",
                             class: "form-input" %>
            </div>

            <div class="filtros-actions filtros-actions--inline">
              <%= submit_tag "Aplicar", class: "button button--primary" %>
              <%= link_to "Ver todas", finanzas_path, class: "button button--ghost" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p><strong><%= @cuenta_financiera_actual&.nombre || "Sin cuenta financiera asignada" %></strong></p>
      <% end %>
    </div>

    <% if modo_global %>
      <div class="empty-state">
        Vista global del administrador. Cada cuenta financiera se muestra por separado para evitar mezclar ingresos, egresos y saldos.
      </div>
    <% end %>
  </div>

  <% if modo_global %>
    <% if @dashboard_por_cuenta.present? && @dashboard_por_cuenta.any? %>
      <% @dashboard_por_cuenta.each do |resumen| %>
        <% cuenta = resumen[:cuenta] %>
        <% cuenta_params_individual = { cuenta_financiera_id: cuenta.id } %>

        <div class="panel">
          <div class="panel__header">
            <div>
              <h3><%= cuenta.nombre %></h3>
              <p class="panel__description">
                Resumen financiero exclusivo de esta cuenta.
              </p>
            </div>

            <div class="acciones-grupo">
              <%= link_to "Ver cooperaciones",
                          cooperaciones_path(cuenta_params_individual),
                          class: "button button--ghost" %>

              <%= link_to "Ver egresos",
                          egresos_path(cuenta_params_individual),
                          class: "button button--ghost" %>

              <%= link_to "Reportes",
                          finanzas_reportes_path(cuenta_params_individual),
                          class: "button button--primary" %>
            </div>
          </div>

          <div class="finanzas-grid">
            <div class="finanzas-card">
              <span class="finanzas-card__label">Ingresos confirmados</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:total_confirmado] || 0) %>
              </strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Egresos confirmados</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:monto_egresos_confirmados] || 0) %>
              </strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Saldo financiero</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:saldo_financiero] || 0) %>
              </strong>
            </div>
          </div>

          <div class="panel__subsection">
            <h4>Cooperaciones</h4>
          </div>

          <div class="finanzas-grid">
            <div class="finanzas-card">
              <span class="finanzas-card__label">Registradas</span>
              <strong class="finanzas-card__value"><%= resumen[:total_cooperaciones] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Activas</span>
              <strong class="finanzas-card__value"><%= resumen[:cooperaciones_activas] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Completadas</span>
              <strong class="finanzas-card__value"><%= resumen[:cooperaciones_completadas] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Total esperado</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:total_esperado] || 0) %>
              </strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Total confirmado</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:total_confirmado] || 0) %>
              </strong>
            </div>
          </div>

          <div class="panel__subsection">
            <h4>Egresos</h4>
          </div>

          <div class="finanzas-grid">
            <div class="finanzas-card">
              <span class="finanzas-card__label">Registrados</span>
              <strong class="finanzas-card__value"><%= resumen[:total_egresos] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Pendientes de confirmar</span>
              <strong class="finanzas-card__value"><%= resumen[:egresos_registrados] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Confirmados</span>
              <strong class="finanzas-card__value"><%= resumen[:egresos_confirmados] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Cancelados</span>
              <strong class="finanzas-card__value"><%= resumen[:egresos_cancelados] || 0 %></strong>
            </div>

            <div class="finanzas-card">
              <span class="finanzas-card__label">Monto egresado confirmado</span>
              <strong class="finanzas-card__value">
                <%= number_to_currency(resumen[:monto_egresos_confirmados] || 0) %>
              </strong>
            </div>
          </div>

          <div class="panel__subsection">
            <h4>Últimos egresos de <%= cuenta.nombre %></h4>
          </div>

          <% ultimos_egresos = resumen[:ultimos_egresos] %>

          <% if ultimos_egresos.present? && ultimos_egresos.any? %>
            <div class="tabla-wrapper">
              <table class="tabla-base">
                <thead>
                  <tr>
                    <th>Folio</th>
                    <th>Fecha</th>
                    <th>Concepto</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th></th>
                  </tr>
                </thead>

                <tbody>
                  <% ultimos_egresos.each do |egreso| %>
                    <tr>
                      <td><strong><%= egreso.folio_np %></strong></td>
                      <td><%= egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></td>
                      <td><%= egreso.concepto %></td>
                      <td><strong><%= number_to_currency(egreso.monto) %></strong></td>

                      <td>
                        <span class="estado-badge estado-badge--<%= egreso.estado %>">
                          <%= egreso.estado.humanize %>
                        </span>
                      </td>

                      <td class="tabla-base__acciones">
                        <%= link_to "Ver", egreso_path(egreso), class: "button button--ghost" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty-state">
              Todavía no hay egresos registrados en esta cuenta.
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="panel">
        <div class="empty-state">
          No hay cuentas financieras activas para mostrar.
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="panel">
      <div class="panel__header">
        <div>
          <h3><%= @cuenta_financiera_actual&.nombre || "Cuenta financiera" %></h3>
          <p class="panel__description">
            Resumen financiero exclusivo de la cuenta seleccionada.
          </p>
        </div>
      </div>

      <div class="finanzas-grid">
        <div class="finanzas-card">
          <span class="finanzas-card__label">Ingresos confirmados</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@total_confirmado || 0) %>
          </strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Egresos confirmados</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@monto_egresos_confirmados || 0) %>
          </strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Saldo financiero</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@saldo_financiero || 0) %>
          </strong>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Resumen de cooperaciones</h3>
          <p class="panel__description">
            Estado general de las corridas de cooperación registradas en esta cuenta.
          </p>
        </div>
      </div>

      <div class="finanzas-grid">
        <div class="finanzas-card">
          <span class="finanzas-card__label">Cooperaciones registradas</span>
          <strong class="finanzas-card__value"><%= @total_cooperaciones || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Cooperaciones activas</span>
          <strong class="finanzas-card__value"><%= @cooperaciones_activas || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Cooperaciones completadas</span>
          <strong class="finanzas-card__value"><%= @cooperaciones_completadas || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Total esperado</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@total_esperado || 0) %>
          </strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Total confirmado</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@total_confirmado || 0) %>
          </strong>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Resumen de egresos</h3>
          <p class="panel__description">
            Estado general de las salidas de dinero registradas en esta cuenta.
          </p>
        </div>
      </div>

      <div class="finanzas-grid">
        <div class="finanzas-card">
          <span class="finanzas-card__label">Egresos registrados</span>
          <strong class="finanzas-card__value"><%= @total_egresos || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Pendientes de confirmar</span>
          <strong class="finanzas-card__value"><%= @egresos_registrados || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Egresos confirmados</span>
          <strong class="finanzas-card__value"><%= @egresos_confirmados || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Egresos cancelados</span>
          <strong class="finanzas-card__value"><%= @egresos_cancelados || 0 %></strong>
        </div>

        <div class="finanzas-card">
          <span class="finanzas-card__label">Monto egresado confirmado</span>
          <strong class="finanzas-card__value">
            <%= number_to_currency(@monto_egresos_confirmados || 0) %>
          </strong>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel__header">
        <div>
          <h3>Últimos egresos</h3>
          <p class="panel__description">
            Salidas de dinero registradas recientemente en esta cuenta.
          </p>
        </div>
      </div>

      <% if @ultimos_egresos.present? && @ultimos_egresos.any? %>
        <div class="tabla-wrapper">
          <table class="tabla-base">
            <thead>
              <tr>
                <th>Folio</th>
                <th>Fecha</th>
                <th>Concepto</th>
                <th>Monto</th>
                <th>Estado</th>
                <th></th>
              </tr>
            </thead>

            <tbody>
              <% @ultimos_egresos.each do |egreso| %>
                <tr>
                  <td><strong><%= egreso.folio_np %></strong></td>
                  <td><%= egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></td>
                  <td><%= egreso.concepto %></td>
                  <td><strong><%= number_to_currency(egreso.monto) %></strong></td>

                  <td>
                    <span class="estado-badge estado-badge--<%= egreso.estado %>">
                      <%= egreso.estado.humanize %>
                    </span>
                  </td>

                  <td class="tabla-base__acciones">
                    <%= link_to "Ver", egreso_path(egreso), class: "button button--ghost" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">
          Todavía no hay egresos registrados.
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Accesos rápidos</h3>
        <p class="panel__description">
          Opciones principales del área financiera.
        </p>
      </div>
    </div>

    <div class="finanzas-actions">
      <%= link_to "Nueva cooperación", new_cooperacion_path(cuenta_params), class: "button button--primary" %>
      <%= link_to "Control de cooperaciones", cooperaciones_path(cuenta_params), class: "button button--ghost" %>
      <%= link_to "Nuevo egreso", new_egreso_path(cuenta_params), class: "button button--primary" %>
      <%= link_to "Control de egresos", egresos_path(cuenta_params), class: "button button--ghost" %>
      <%= link_to "Reportes financieros", finanzas_reportes_path(cuenta_params), class: "button button--primary" %>
    </div>
  </div>
</section>