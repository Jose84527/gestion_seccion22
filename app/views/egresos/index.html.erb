<% content_for :title, "Egresos" %>
<% content_for :page_title, "Egresos" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Control de egresos</h3>
        <p class="panel__description">
          Registro y control de salidas de dinero de la Secretaría de Finanzas.
        </p>
      </div>

      <% if puede_realizar_accion?(:cooperaciones, :crear) %>
        <%= link_to "Nuevo egreso", new_egreso_path, class: "button button--primary" %>
      <% end %>
    </div>

    <%= form_with url: egresos_path, method: :get, local: true, class: "filtros-panel" do %>
      <div class="filtros-grid filtros-grid--cooperaciones">
        <div class="form-field">
          <label for="q">Buscar</label>
          <%= text_field_tag :q,
                             @q,
                             class: "form-input",
                             placeholder: "Folio N.P. o concepto" %>
        </div>

        <div class="form-field">
          <label for="estado">Estado</label>
          <%= select_tag :estado,
                         options_for_select(
                           [
                             ["Todos", ""],
                             ["Registrado", "registrado"],
                             ["Confirmado", "confirmado"],
                             ["Cancelado", "cancelado"]
                           ],
                           @estado
                         ),
                         class: "form-input" %>
        </div>
      </div>

      <div class="filtros-actions">
        <%= submit_tag "Filtrar", class: "button button--primary" %>
        <%= link_to "Limpiar", egresos_path, class: "button button--ghost" %>
      </div>
    <% end %>

    <% if @egresos.any? %>
      <div class="listado-meta">
        <span>
          Mostrando <strong><%= @egresos.size %></strong> de
          <strong><%= @total_registros %></strong> egresos
        </span>

        <span>
          Página <strong><%= @pagina_actual %></strong> de
          <strong><%= @total_paginas %></strong>
        </span>
      </div>

      <div class="tabla-wrapper">
        <table class="tabla-base">
          <thead>
            <tr>
              <th>Folio</th>
              <th>Fecha</th>
              <th>Concepto</th>
              <th>Monto</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>

          <tbody>
            <% @egresos.each do |egreso| %>
              <tr>
                <td>
                  <strong><%= egreso.folio_np %></strong>
                </td>

                <td>
                  <%= egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %>
                </td>

                <td>
                  <%= egreso.concepto %>
                </td>

                <td>
                  <strong><%= number_to_currency(egreso.monto) %></strong>
                </td>

                <td>
                  <span class="estado-badge estado-badge--<%= egreso.estado %>">
                    <%= egreso.estado.humanize %>
                  </span>
                </td>

                <td class="tabla-base__acciones">
                  <div class="acciones-grupo">
                    <%= link_to "Ver",
                                egreso_path(egreso),
                                class: "button button--ghost" %>

                    <% if puede_realizar_accion?(:cooperaciones, :editar) && egreso.registrado? %>
                      <%= link_to "Confirmar",
                                  confirmacion_egreso_path(egreso),
                                  class: "button button--primary" %>

                      <%= link_to "Editar",
                                  edit_egreso_path(egreso),
                                  class: "button button--ghost" %>

                      <%= button_to "Cancelar",
                                    cancelar_egreso_path(egreso),
                                    method: :patch,
                                    class: "button button--ghost",
                                    data: {
                                      turbo_confirm: "¿Seguro que deseas cancelar este egreso?"
                                    } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_paginas.to_i > 1 %>
        <div class="pagination">
          <% if @pagina_actual > 1 %>
            <%= link_to "← Anterior",
                        egresos_path(request.query_parameters.merge(page: @pagina_actual - 1)),
                        class: "button button--ghost" %>
          <% end %>

          <% (1..@total_paginas).each do |pagina| %>
            <%= link_to pagina,
                        egresos_path(request.query_parameters.merge(page: pagina)),
                        class: "pagination__link #{'is-active' if pagina == @pagina_actual}" %>
          <% end %>

          <% if @pagina_actual < @total_paginas %>
            <%= link_to "Siguiente →",
                        egresos_path(request.query_parameters.merge(page: @pagina_actual + 1)),
                        class: "button button--ghost" %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        No se encontraron egresos con los filtros seleccionados.
      </div>
    <% end %>
  </div>
</section>