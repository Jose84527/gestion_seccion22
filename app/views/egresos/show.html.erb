<% content_for :title, "Detalle de egreso" %>
<% content_for :page_title, "Detalle de egreso" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3><%= @egreso.folio_np %></h3>
        <p class="panel__description">
          Detalle del egreso registrado por Finanzas.
        </p>
      </div>

      <div class="acciones-grupo">
        <%= link_to "Volver", egresos_path, class: "button button--ghost" %>

        <% if puede_realizar_accion?(:cooperaciones, :editar) && @egreso.registrado? %>
          <%= link_to "Editar", edit_egreso_path(@egreso), class: "button button--primary" %>
        <% end %>
      </div>
    </div>

    <div class="detalle-grid">
      <div class="detalle-item">
        <span class="detalle-item__label">Folio N.P.</span>
        <strong><%= @egreso.folio_np %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Número N.P.</span>
        <strong><%= @egreso.numero_np %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Monto</span>
        <strong><%= number_to_currency(@egreso.monto) %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Fecha del egreso</span>
        <strong><%= @egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Estado</span>
        <strong>
          <span class="estado-badge estado-badge--<%= @egreso.estado %>">
            <%= @egreso.estado.humanize %>
          </span>
        </strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Confirmado el</span>
        <strong><%= @egreso.confirmado_at&.strftime("%d/%m/%Y %H:%M") || "-" %></strong>
      </div>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Concepto</span>
      <p><%= @egreso.concepto %></p>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Observaciones</span>

      <% if @egreso.observaciones.present? %>
        <div class="observaciones-confirmacion">
          <%= simple_format(@egreso.observaciones) %>
        </div>
      <% else %>
        <p>-</p>
      <% end %>
    </div>

    <% if @egreso.confirmado? %>
      <div class="detalle-bloque">
        <span class="detalle-item__label">Evidencia PDF</span>
        <p><%= @egreso.evidencia_pdf_path.presence || "-" %></p>
      </div>

      <div class="detalle-bloque">
        <span class="detalle-item__label">Observaciones de evidencia</span>

        <% if @egreso.observaciones_evidencia.present? %>
          <div class="observaciones-confirmacion">
            <%= simple_format(@egreso.observaciones_evidencia) %>
          </div>
        <% else %>
          <p>-</p>
        <% end %>
      </div>
    <% end %>

    <div class="finanzas-actions">
      <% if @egreso.registrado? && puede_realizar_accion?(:cooperaciones, :editar) %>
        <%= button_to "Cancelar egreso",
                      cancelar_egreso_path(@egreso),
                      method: :patch,
                      class: "button button--ghost",
                      data: {
                        turbo_confirm: "¿Seguro que deseas cancelar este egreso?"
                      } %>
      <% end %>

      <% unless @egreso.cancelado? %>
        <%= link_to "Generar PDF",
                    pdf_egreso_path(@egreso),
                    class: "button button--ghost",
                    target: "_blank",
                    rel: "noopener" %>
      <% else %>
        <span class="button button--ghost is-disabled">PDF no disponible</span>
      <% end %>

      <% if @egreso.registrado? && puede_realizar_accion?(:cooperaciones, :editar) %>
        <%= link_to "Confirmar egreso",
                    confirmacion_egreso_path(@egreso),
                    class: "button button--primary" %>
      <% elsif @egreso.confirmado? && @egreso.evidencia_pdf_path.present? %>
        <%= link_to "Ver evidencia",
                    ver_evidencia_egreso_path(@egreso),
                    class: "button button--primary",
                    target: "_blank",
                    rel: "noopener" %>

        <% if puede_realizar_accion?(:cooperaciones, :editar) %>
          <%= link_to "Corregir evidencia",
                      corregir_evidencia_egreso_path(@egreso),
                      class: "button button--ghost" %>
        <% end %>
      <% elsif @egreso.cancelado? %>
        <span class="button button--ghost is-disabled">Egreso cancelado</span>
      <% end %>
    </div>
  </div>
</section>