<% content_for :title, "Corregir evidencia" %>
<% content_for :page_title, "Corregir evidencia" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Corregir evidencia del egreso</h3>
        <p class="panel__description">
          Esta acción solo reemplaza el PDF escaneado. El egreso seguirá confirmado.
        </p>
      </div>

      <%= link_to "Volver", egreso_path(@egreso), class: "button button--ghost" %>
    </div>

    <div class="detalle-grid">
      <div class="detalle-item">
        <span class="detalle-item__label">Folio N.P.</span>
        <strong><%= @egreso.folio_np %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Monto</span>
        <strong><%= number_to_currency(@egreso.monto) %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Estado</span>
        <strong>
          <span class="estado-badge estado-badge--<%= @egreso.estado %>">
            <%= @egreso.estado.humanize %>
          </span>
        </strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Confirmado el</span>
        <strong><%= @egreso.confirmado_at&.strftime("%d/%m/%Y %H:%M") || "-" %></strong>
      </div>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Evidencia actual</span>
      <p><%= @egreso.evidencia_pdf_path.presence || "-" %></p>

      <% if @egreso.evidencia_pdf_path.present? %>
        <div class="finanzas-actions">
          <%= link_to "Ver evidencia actual",
                      ver_evidencia_egreso_path(@egreso),
                      class: "button button--ghost",
                      target: "_blank",
                      rel: "noopener" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Nueva evidencia</h3>
        <p class="panel__description">
          Sube el PDF correcto y escribe el motivo de la corrección.
        </p>
      </div>
    </div>

    <%= form_with url: actualizar_evidencia_egreso_path(@egreso),
                  method: :patch,
                  local: true,
                  html: { multipart: true },
                  class: "formulario-base" do %>

      <div class="form-grid form-grid--dos-columnas">
        <div class="form-field">
          <%= label_tag :evidencia_pdf, "Nuevo PDF escaneado" %>
          <%= file_field_tag :evidencia_pdf,
                             accept: "application/pdf,.pdf",
                             class: "form-input" %>

          <small class="helper-text">
            Este archivo reemplazará la evidencia visible del egreso.
          </small>
        </div>

        <div class="form-field">
          <%= label_tag :motivo_correccion, "Motivo de corrección" %>
          <%= text_area_tag :motivo_correccion,
                            params[:motivo_correccion],
                            class: "form-input form-textarea",
                            rows: 4,
                            maxlength: 1000,
                            placeholder: "Ejemplo: Se subió un comprobante incompleto por error." %>

          <small class="helper-text">
            El motivo quedará registrado en historial.
          </small>
        </div>
      </div>

      <div class="form-actions">
        <%= link_to "Cancelar", egreso_path(@egreso), class: "button button--ghost" %>

        <%= submit_tag "Actualizar evidencia",
                       class: "button button--primary",
                       data: {
                         turbo_confirm: "¿Confirmas que deseas reemplazar el PDF de evidencia?"
                       } %>
      </div>
    <% end %>
  </div>
</section>