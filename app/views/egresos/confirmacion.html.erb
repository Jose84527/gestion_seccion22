<% content_for :title, "Confirmar egreso" %>
<% content_for :page_title, "Confirmar egreso" %>

<section class="catalogo-page">
  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Confirmar egreso</h3>
        <p class="panel__description">
          Sube el PDF escaneado y firmado para confirmar la salida de dinero.
        </p>
      </div>

      <%= link_to "Volver", egreso_path(@egreso), class: "button button--ghost" %>
    </div>

    <div class="detalle-grid">
      <div class="detalle-item">
        <span class="detalle-item__label">Folio N.P.</span>
        <strong><%= @egreso.folio_np %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Monto</span>
        <strong><%= number_to_currency(@egreso.monto) %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Fecha del egreso</span>
        <strong><%= @egreso.fecha_egreso&.strftime("%d/%m/%Y") || "-" %></strong>
      </div>

      <div class="detalle-item">
        <span class="detalle-item__label">Estado actual</span>
        <strong>
          <span class="estado-badge estado-badge--<%= @egreso.estado %>">
            <%= @egreso.estado.humanize %>
          </span>
        </strong>
      </div>
    </div>

    <div class="detalle-bloque">
      <span class="detalle-item__label">Concepto</span>
      <p><%= @egreso.concepto %></p>
    </div>
  </div>

  <div class="panel">
    <div class="panel__header">
      <div>
        <h3>Evidencia escaneada</h3>
        <p class="panel__description">
          Sube el recibo firmado en formato PDF.
        </p>
      </div>
    </div>

    <%= form_with url: confirmar_egreso_path(@egreso),
                  method: :patch,
                  local: true,
                  html: { multipart: true },
                  class: "formulario-base" do %>

      <div class="form-grid form-grid--dos-columnas">
        <div class="form-field">
          <%= label_tag :evidencia_pdf, "PDF escaneado del egreso" %>
          <%= file_field_tag :evidencia_pdf,
                             accept: "application/pdf,.pdf",
                             class: "form-input" %>

          <small class="helper-text">
            Este archivo se guardará en Supabase Storage dentro del bucket de egresos.
          </small>
        </div>

        <div class="form-field">
          <%= label_tag :observaciones_evidencia, "Observaciones de evidencia" %>
          <%= text_area_tag :observaciones_evidencia,
                            params[:observaciones_evidencia],
                            class: "form-input form-textarea",
                            rows: 4,
                            maxlength: 1000,
                            placeholder: "Opcional: observaciones sobre el comprobante firmado." %>

          <small class="helper-text">
            Estas observaciones quedarán registradas en el egreso.
          </small>
        </div>
      </div>

      <div class="form-actions">
        <%= link_to "Cancelar", egreso_path(@egreso), class: "button button--ghost" %>

        <%= submit_tag "Confirmar egreso",
                       class: "button button--primary",
                       data: {
                         turbo_confirm: "¿Confirmas que este egreso debe marcarse como confirmado?"
                       } %>
      </div>
    <% end %>
  </div>
</section>