<%= form_with model: concepto07_nivel, class: "formulario-base", novalidate: true do |f| %>
  <% if concepto07_nivel.errors.any? %>
    <div class="form-errors">
      <strong>No se pudo guardar la categoría:</strong>
      <ul>
        <% concepto07_nivel.errors.full_messages.each do |mensaje| %>
          <li><%= mensaje %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid form-grid--dos-columnas">
    <div class="form-field form-field--full">
      <label>Clave</label>
      <input type="text"
             class="form-input"
             value="<%= concepto07_nivel.persisted? ? concepto07_nivel.clave : 'Se generará automáticamente (CP-01, CP-02...)' %>"
             disabled>
      <small class="helper-text">La clave la genera automáticamente el sistema.</small>
    </div>

    <div class="form-field">
      <%= f.label :nombre, "Nombre de categoría" %>
      <%= f.text_field :nombre,
                       class: "form-input #{'form-input--error' if concepto07_nivel.errors[:nombre].any?}",
                       minlength: 3,
                       maxlength: 100 %>
      <% if concepto07_nivel.errors[:nombre].any? %>
        <small class="field-error"><%= concepto07_nivel.errors[:nombre].first %></small>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :monto_concepto07, "Monto concepto 07" %>
      <%= f.number_field :monto_concepto07,
                         class: "form-input #{'form-input--error' if concepto07_nivel.errors[:monto_concepto07].any?}",
                         step: "0.01",
                         min: "0.01" %>
      <% if concepto07_nivel.errors[:monto_concepto07].any? %>
        <small class="field-error"><%= concepto07_nivel.errors[:monto_concepto07].first %></small>
      <% else %>
        <small class="helper-text">Captura el salario base correspondiente a esta categoría.</small>
      <% end %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", concepto07_niveles_path, class: "button button--ghost" %>
    <%= f.submit concepto07_nivel.persisted? ? "Actualizar categoría" : "Guardar categoría",
                 class: "button button--primary" %>
  </div>
<% end %>