<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gestion Seccion22" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= [sesion_iniciada? ? 'layout-auth' : 'layout-public', (content_for(:body_class) if content_for?(:body_class))].compact.join(' ') %>">
    <% if sesion_iniciada? %>
      <div class="app-shell">
        <%= render "shared/sidebar" %>

        <div class="app-shell__main">
          <%= render "shared/topbar" %>

          <main class="app-content">
            <%= render "shared/flash" %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="public-content">
        <%= render "shared/flash" %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>